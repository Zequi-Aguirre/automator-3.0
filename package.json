{
  "name": "automator-json-server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev-fe": "doppler run -c dev --scope automator -- vite client --force",
    "dev-be": "doppler run -c dev --scope automator -- nodemon --exitcrash server/src/main/server.ts",
    "dev-db-start": "cd postgres && ./start.sh",
    "dev-db-migrate": "doppler run --scope automator --project automator --config dev --command 'cd postgres && ./migrate.sh'",
    "dev-db-stop": "cd postgres && ./stop.sh",
    "dev-db-reset": "npm run dev-db-stop && npm run dev-db-start && npm run dev-db-migrate && npm run dev-db-seed",
    "dev-db-seed": "doppler run --scope automator --project automator --config dev --command 'cd postgres && ./seed.sh'",
    "load-test-data": "podman cp postgres/seed-test-data.sql automator-dev:/tmp/ && podman exec automator-dev psql -U automator -d automator -f /tmp/seed-test-data.sql",
    "create-migration": "node postgres/createMigration.js",
    "dev-css": "npx tailwindcss -i ./client/src/tailwind.css -o ./client/src/landing/style.css --watch",
    "build": "npx tailwindcss -i ./client/src/tailwind.css -o ./client/src/landing/style.css && npm run build-fe && npm run build-be",
    "build-fe": "tsc --p client/tsconfig.json && vite build client",
    "build-be": "tsc --p server/tsconfig.json && node server/bundler.mjs",
    "start-be": "node dist/server.js",
    "lint": "npm run lint-fe && npm run lint-be",
    "lint-fe": "eslint client/src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint-be": "eslint server/src --ext ts,tsx --report-unused-disable-directives --max-warnings 1000",
    "preview": "cd client && vite preview",
    "db-migrate": "cd postgres && ./migrate.sh",
    "db-migrate-stg": "cd postgres && ./migrate.sh",
    "counties-script": "doppler run -c dev --scope automator -- node scripts/load-counties-script/loadCountyData.js",
    "counties-deploy": "node scripts/load-counties-script/loadCountyData.js",
    "export-prod-data": "doppler run -c prd --scope automator -- node scripts/exportProdData.js",
    "export-staging-data": "doppler run -c stg --scope automator -- node scripts/exportStagingData.js",
    "import-prod-data-dev": "doppler run -c dev --scope automator -- node scripts/importProdData.js",
    "import-prod-data-stg": "doppler run -c stg --scope automator -- node scripts/importProdData.js",
    "import-prod-data-prd": "doppler run -c prd --scope automator -- node scripts/importProdData.js",
    "delete-prod-db": "doppler run -c prd --scope automator -- node scripts/wipeDb.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@fortawesome/fontawesome-svg-core": "^6.4.0",
    "@fortawesome/free-solid-svg-icons": "^6.4.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@mui/icons-material": "^5.16.6",
    "@mui/lab": "^5.0.0-alpha.131",
    "@mui/material": "^5.13.1",
    "@mui/x-data-grid": "^6.14.0",
    "@mui/x-date-pickers": "^8.27.2",
    "@sendgrid/mail": "^7.7.0",
    "@supabase/supabase-js": "^2.24.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.7",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.5.0",
    "csv": "^6.4.1",
    "csv-parser": "^3.0.0",
    "csvtojson": "^2.0.10",
    "dayjs": "^1.11.7",
    "doppler": "^1.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.474.0",
    "luxon": "^3.7.2",
    "moment-timezone": "^0.5.44",
    "mongodb": "^6.12.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.12.0",
    "pg": "^8.13.1",
    "pg-native": "^3.1.0",
    "pg-promise": "^11.5.4",
    "querystring": "^0.2.1",
    "react": "^18.2.0",
    "react-apexcharts": "^1.4.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.2",
    "react-swipeable-list": "^1.9.3",
    "react-toastify": "^10.0.5",
    "reflect-metadata": "^0.1.13",
    "sequelize": "^6.37.5",
    "stripe": "^12.8.0",
    "ts-mockito": "2.6.1",
    "tsyringe": "^4.8.0",
    "twilio": "^5.0.2",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.4",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/morgan": "^1.9.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.2.5",
    "@types/pg": "^8.10.2",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/supertest": "^2.0.12",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.0.1",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "concurrently": "^8.0.1",
    "date-fns": "^4.1.0",
    "esbuild": "^0.17.19",
    "esbuild-decorators": "^1.0.0",
    "esbuild-plugin-tsc": "^0.4.0",
    "eslint": "^8.14.0",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "jest-mock-extended": "^3.0.5",
    "nodemon": "^2.0.22",
    "npm-run-all": "^4.1.5",
    "postgrator": "^7.2.0",
    "postgrator-cli": "^7.0.0",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.1.0",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^4.3.2"
  }
}
